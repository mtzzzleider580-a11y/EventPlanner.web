@model EventPlanner.Web.Models.Usuario
@using EventPlanner.Web.Models

@{
    ViewBag.Title = "Registro";
}

<link href="~/Content/Registro.css" rel="stylesheet" />

<div class="contenedor-registro">

    <h2 class="titulo-registro">
        Registro de Aprendiz
    </h2>

    <form method="post">

        <div class="grupo-formulario">
            <label>Tipo Documento</label>

            <select name="TipoDocumento" required>
                <option value="">Seleccione</option>
                <option value="CC">Cédula de Ciudadanía</option>
                <option value="TI">Tarjeta de Identidad</option>
                <option value="CE">Cédula de Extranjería</option>
                <option value="PASAPORTE">Pasaporte</option>
            </select>
        </div>

        <div class="grupo-formulario">
            <label>Número Documento</label>
            <input type="text" name="NumeroDocumento" required />
        </div>

        <div class="grupo-formulario">
            <label>Nombre Completo</label>
            <input type="text" name="NombreCompleto" required />
        </div>

        <div class="grupo-formulario">
            <label>Correo Electrónico</label>
            <input type="email" name="Correo" required />
        </div>

        <div class="grupo-formulario">
            <label>Ficha</label>
            <input type="text" name="Ficha" required />
        </div>

        <div class="grupo-formulario">
            <label>Jornada</label>

            <select name="Jornada" required>
                <option value="">Seleccione</option>
                <option value="Mañana">Mañana</option>
                <option value="Tarde">Tarde</option>
                <option value="Noche">Noche</option>
            </select>
        </div>

        <div class="grupo-formulario">
            <label>Programa de Formación</label>

            <select name="idProgramaFormacion" required>

                <option value="">
                    Seleccione Programa
                </option>

                @foreach (ProgramaFormacion programa in ViewBag.Programas)
                {
                    <option value="@programa.idProgramaFormacion">
                        @programa.NombrePrograma
                    </option>
                }

            </select>
        </div>

        <div class="grupo-formulario">
            <label>Contraseña</label>
            <input type="password" name="Contrasena" required />
        </div>

        <button type="submit" class="btn-registro">
            Registrarse
        </button>

    </form>

    @if (ViewBag.Mensaje != null)
    {
        <div class="mensaje-exito">
            @ViewBag.Mensaje
        </div>
    }

</div>