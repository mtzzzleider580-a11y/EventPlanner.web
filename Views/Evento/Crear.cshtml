@model EventPlanner.Web.Models.Evento

@using EventPlanner.Web.Models

@{
    ViewBag.Title = "Crear Evento";

    var tipos = ViewBag.TiposEvento as List<TipoEvento>;
}

<div class="container mt-4">

    <h2>Crear Evento</h2>

    <hr />

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Mensaje
        </div>
    }

    @using (Html.BeginForm())
    {
        <div class="row">

            <div class="col-md-6 mb-3">

                <label>Tipo Evento</label>

                <select name="idTipoEvento"
                        class="form-control"
                        required>

                    <option value="">
                        Seleccione
                    </option>

                    @foreach (var item in tipos)
                    {
                        <option value="@item.idTipoEvento">

                            @item.NombreTipoEvento

                        </option>
                    }

                </select>

            </div>

            <div class="col-md-6 mb-3">

                <label>Nombre Evento</label>

                <input type="text"
                       name="NombreEvento"
                       class="form-control"
                       required />

            </div>

        </div>

        <div class="mb-3">

            <label>Descripción</label>

            <textarea name="Descripcion"
                      class="form-control"
                      rows="3"
                      required></textarea>

        </div>

        <div class="row">

            <div class="col-md-6 mb-3">

                <label>Modalidad</label>

                <select name="Modalidad"
                        class="form-control"
                        required>

                    <option value="">
                        Seleccione
                    </option>

                    <option value="INDIVIDUAL">
                        INDIVIDUAL
                    </option>

                    <option value="EQUIPO">
                        EQUIPO
                    </option>

                </select>

            </div>

            <div class="col-md-6 mb-3">

                <label>Lugar</label>

                <input type="text"
                       name="Lugar"
                       class="form-control"
                       required />

            </div>

        </div>

        <div class="row">

            <div class="col-md-4 mb-3">

                <label>Fecha Evento</label>

                <input type="date"
                       name="FechaEvento"
                       class="form-control"
                       required />

            </div>

            <div class="col-md-4 mb-3">

                <label>Hora Inicio</label>

                <input type="time"
                       name="HoraInicio"
                       class="form-control"
                       required />

            </div>

            <div class="col-md-4 mb-3">

                <label>Hora Fin</label>

                <input type="time"
                       name="HoraFin"
                       class="form-control"
                       required />

            </div>

        </div>

        <div class="row">

            <div class="col-md-4 mb-3">

                <label>Cupos Totales</label>

                <input type="number"
                       name="CuposTotales"
                       class="form-control"
                       min="1"
                       required />

            </div>

            <div class="col-md-4 mb-3">

                <label>Inicio Inscripción</label>

                <input type="date"
                       name="FechaInicioInscripcion"
                       class="form-control"
                       required />

            </div>

            <div class="col-md-4 mb-3">

                <label>Fin Inscripción</label>

                <input type="date"
                       name="FechaFinInscripcion"
                       class="form-control"
                       required />

            </div>

        </div>

        <button type="submit"
                class="btn btn-success">

            Guardar Evento

        </button>

        <a href="@Url.Action("Index","Evento")"
           class="btn btn-secondary">

            Volver

        </a>
    }

</div>