@model EventPlanner.Web.Models.Equipo
@using EventPlanner.Web.Models

@{
    ViewBag.Title = "Editar Equipo";
    var eventos = ViewBag.Eventos as List<Evento>;
}

<div class="container mt-4">
    <h2>Editar Equipo</h2>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger">@ViewBag.Mensaje</div>
    }

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.idEquipo)

        <div class="mb-3">
            <label>Evento</label>
            <select name="idEvento" class="form-control" required>
                <option value="">Seleccione</option>
                @foreach (var ev in eventos)
                {
                    <option value="@ev.idEvento" @(ev.idEvento == Model.idEvento ? "selected" : "")>@ev.NombreEvento (@ev.FechaEvento.ToString("dd/MM/yyyy"))</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label>Nombre Equipo</label>
            @Html.TextBoxFor(m => m.NombreEquipo, new { @class = "form-control", required = "required" })
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Cantidad MÌnima</label>
                @Html.TextBoxFor(m => m.CantidadMinima, new { @type = "number", @class = "form-control", min = "1", required = "required" })
            </div>
            <div class="col-md-6 mb-3">
                <label>Cantidad M·xima</label>
                @Html.TextBoxFor(m => m.CantidadMaxima, new { @type = "number", @class = "form-control", min = "1", required = "required" })
            </div>
        </div>

        <button type="submit" class="btn btn-success">Guardar</button>
        <a href="@Url.Action("Index","Equipo")" class="btn btn-secondary">Volver</a>
    }
</div>